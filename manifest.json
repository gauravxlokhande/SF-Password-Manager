{
  "manifest_version": 3,
  "name": "SF Password Manager",
  "version": "4.0.0",
  "description": "One-click Salesforce org login — directly into your org.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "SF Password Manager"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://*.cloudforce.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
